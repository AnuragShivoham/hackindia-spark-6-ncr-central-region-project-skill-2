# ╔══════════════════════════════════════════════════════════════╗
# ║  AMIT-BODHIT — Backend Environment Configuration            ║
# ║  Copy this file to .env and fill in your values             ║
# ║  Run: cp .env.example .env                                  ║
# ╚══════════════════════════════════════════════════════════════╝

# ─── Server ────────────────────────────────────────────────────
PORT=3001

# ─── AI / LLM Provider ────────────────────────────────────────
# Choose: "groq" (cloud, recommended) or "local" (ollama)
LLM_PROVIDER=groq

# Groq API Key (Free at https://console.groq.com/keys)
GROQ_API_KEY=gsk_your_groq_api_key_here

# Local Ollama (only if LLM_PROVIDER=local)
OLLAMA_BASE_URL=http://localhost:11434
LOCAL_MODEL=phi3:mini

# ─── Database ─────────────────────────────────────────────────
DB_PATH=./data/amitbodhit.db

# ─── Authentication ───────────────────────────────────────────
# IMPORTANT: Change this in production!
JWT_SECRET=change-this-to-a-random-secret

# Google OAuth Client ID (https://console.cloud.google.com)
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com

# ─── Email / OTP ──────────────────────────────────────────────
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_password_here
EMAIL_FROM=AMIT-BODHIT <no-reply@amitbodhit.app>
