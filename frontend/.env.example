# ╔══════════════════════════════════════════════════════════════╗
# ║  AMIT-BODHIT — Frontend Environment Configuration          ║
# ║  Copy this file to .env and fill in your values             ║
# ║  Run: cp .env.example .env                                  ║
# ╚══════════════════════════════════════════════════════════════╝

# ─── Google OAuth ──────────────────────────────────────────────
# Same Client ID used in the backend (from https://console.cloud.google.com)
# Required for Google Sign-In button. Leave empty to hide Google login.
VITE_GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
